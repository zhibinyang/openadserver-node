DATABASE_URL=postgresql://oas:oas_password@localhost:5432/oas
JWT_SECRET=your-secret-key-change-in-production
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Kafka Configuration (for event pipeline)
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=openadserver
KAFKA_COMPRESSION=snappy
EVENT_PRODUCER_MODE=auto

# Calibration mode: direct (default, direct connect Redis) or global (Flink global calculation)
CALIBRATION_MODE=direct
